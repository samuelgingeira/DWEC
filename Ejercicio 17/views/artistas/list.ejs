<h1>🎤 Artistas</h1>

<a class="btn" href="/artista/form">Añadir artista</a>

<div style="display:flex; flex-wrap:wrap; gap:20px; margin-top:20px;">
  <% artistas.forEach(artista => { %>
    <div class="card">
      <img src="<%= artista.foto || 'https://via.placeholder.com/150' %>" width="150">
      <h3>
        <a href="/artista/<%= artista.id %>"><%= artista.nombre %></a>
      </h3>
      <a href="/artista/form/<%= artista.id %>">Editar</a> |
      <a href="/artista/delete/<%= artista.id %>">Eliminar</a>
    </div>
  <% }) %>
</div>
